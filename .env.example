# ─────────────────────────────────────────────────────────────
# NaqiJo — environment template. Copy to `.env` and fill in.
# In production, set these in your host's dashboard (Vercel / Docker / etc.),
# never commit real secrets. `.env` is gitignored.
# ─────────────────────────────────────────────────────────────

# ── Core (required) ──────────────────────────────────────────
# Long random string that signs auth JWTs + cookies. REQUIRED in production
# (the app refuses to boot without it). Generate: `openssl rand -hex 32`
PAYLOAD_SECRET=

# Database connection.
#  • Local dev: a SQLite file (zero setup, no server).
#  • Production: the Supabase Postgres **pooler** connection string
#    (Supabase → Project Settings → Database → Connection pooling, mode=Transaction).
DATABASE_URI=file:./naqijo.db
# DATABASE_URI=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Public base URL of the site — used for canonical/OG tags, sitemap, robots,
# Payload serverURL/CORS/CSRF, and email links. No trailing slash.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ── Media storage (Supabase Storage, S3-compatible) ──────────
# When S3_BUCKET + S3_ACCESS_KEY_ID are set, uploads go to Supabase Storage
# instead of the local disk. REQUIRED in production (serverless disks are
# ephemeral). Create a PUBLIC bucket + S3 access keys in Supabase → Storage.
# S3_ENDPOINT=https://<ref>.supabase.co/storage/v1/s3
# S3_REGION=us-east-1
# S3_BUCKET=naqijo-media
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# ── Email (optional — enables password resets + notifications) ─
# Provide EITHER Resend OR SMTP. If neither is set, emails log to the console.
# Resend (preferred):
# RESEND_API_KEY=
# SMTP (alternative):
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
# From address/name used by both:
# EMAIL_FROM_ADDRESS=noreply@naqijo.com
# EMAIL_FROM_NAME=NaqiJo

# ── First admin (used by the seed script only) ───────────────
# If SEED_ADMIN_PASSWORD is omitted, the seed generates a strong random
# password and prints it once. Change it after first login.
# SEED_ADMIN_EMAIL=admin@naqijo.com
# SEED_ADMIN_PASSWORD=

# ── Observability (optional) ─────────────────────────────────
# LOG_LEVEL=info
# SENTRY_DSN=

# ── Build (optional) ─────────────────────────────────────────
# Set to "standalone" for a minimal self-hosted Node server build.
# NEXT_OUTPUT=standalone
