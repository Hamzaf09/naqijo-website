# ─────────────────────────────────────────────────────────────
# NaqiJo CMS — environment template. Copy to `.env` and fill in.
# ─────────────────────────────────────────────────────────────

# A long random string (e.g. `openssl rand -hex 32`). Required.
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Database.
#  • Local dev: leave as a SQLite file (no server needed).
#  • Production: use your Supabase Postgres connection string (the
#    connection pooler URL from Supabase → Project Settings → Database).
DATABASE_URI=file:./naqijo.db
# DATABASE_URI=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Public base URL of the site (used for absolute links, previews, OG tags).
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ── Supabase Storage (S3-compatible) — production media ──────────
# When these are set, uploaded media is stored in Supabase Storage
# instead of the local disk. From Supabase → Storage → S3 access keys.
# S3_ENDPOINT=https://<ref>.supabase.co/storage/v1/s3
# S3_REGION=us-east-1
# S3_BUCKET=naqijo-media
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
